<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base config for all domains -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Specific domain configurations -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.1.10</domain>
        <domain includeSubdomains="true">192.168.1.11</domain>
        <domain includeSubdomains="true">192.168.1.8</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain> <!-- For emulator -->
    </domain-config>

    <!-- Streaming and CDN domains -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">demo.unified-streaming.com</domain>
        <domain includeSubdomains="true">storage.googleapis.com</domain>
        <domain includeSubdomains="true">youtube.com</domain>
        <domain includeSubdomains="true">ytimg.com</domain>
        <domain includeSubdomains="true">googlevideo.com</domain>
        <domain includeSubdomains="true">ggpht.com</domain>
    </domain-config>

    <!-- TMDB domains -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.themoviedb.org</domain>
        <domain includeSubdomains="true">image.tmdb.org</domain>
        <domain includeSubdomains="true">themoviedb.org</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Unsplash domains for background images -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">images.unsplash.com</domain>
        <domain includeSubdomains="true">unsplash.com</domain>
    </domain-config>
</network-security-config>