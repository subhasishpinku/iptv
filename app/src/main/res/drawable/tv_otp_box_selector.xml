<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/transparent" />
            <stroke
                android:width="3dp"
                android:color="@color/red" />
            <corners android:radius="12dp" />
            <padding
                android:top="4dp"
                android:bottom="4dp"
                android:left="4dp"
                android:right="4dp" />
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="@color/semi_transparent_dark" />
            <stroke
                android:width="1dp"
                android:color="@color/light_gray" />
            <corners android:radius="12dp" />
            <padding
                android:top="4dp"
                android:bottom="4dp"
                android:left="4dp"
                android:right="4dp" />
        </shape>
    </item>
</selector>