<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_movies"
        android:scaleType="centerCrop" />

    <!-- Dark Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" />

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="450dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:background="@drawable/bg_card">

        <!-- Title -->
        <RelativeLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/signIn"
                android:text="Sign In"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/skipId"
                android:layout_width="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_height="wrap_content"
                android:text="Skip"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:background="@drawable/tv_focus_bg"
                android:nextFocusUp="@id/tvForgot"
                />
        </RelativeLayout>


        <!-- Phone / Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="25dp"
            android:hint="Enter Phone number"
            android:inputType="number"
            android:imeOptions="actionDone"
            android:maxLength="10"
            android:textColorHint="@color/black"
            android:textColor="@android:color/black"
            android:background="@drawable/bg_edittext"
            android:padding="14dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/btnLogin"/>

        <!-- Sign In Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_marginLeft="80dp"
            android:layout_marginRight="80dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="50dp"
            android:text="Sign In"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#E50914"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/etEmail"
            android:nextFocusDown="@id/cbRemember"/>

        <!-- Remember + Forgot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cbRemember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remember me"
                android:textColor="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusUp="@id/btnLogin"
                android:nextFocusRight="@id/tvForgot"/>

            <TextView
                android:id="@+id/tvForgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password"
                android:textColor="@android:color/white"
                android:layout_marginStart="150dp"
                android:padding="6dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:background="@drawable/tv_focus_bg"
                android:nextFocusLeft="@id/cbRemember"
                android:nextFocusDown="@id/tvSignup"/>
        </LinearLayout>

        <!-- Sign Up -->
        <TextView
            android:id="@+id/tvSignup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="New here? Sign up now."
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:padding="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:background="@drawable/tv_focus_bg"
            android:nextFocusUp="@id/tvForgot"/>



    </LinearLayout>

</FrameLayout>
