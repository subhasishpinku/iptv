<?xml version="1.0" encoding="utf-8"?>
<androidx.leanback.widget.NonOverlappingLinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="0dp"
    android:paddingBottom="8dp"
    android:layout_marginTop="0dp">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/header_icon"
            android:scaleType="centerInside"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:adjustViewBounds="true" />

        <TextView
            android:id="@+id/header_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:textAllCaps="true"
            android:textColor="@color/card_primary_text"
            android:textSize="@dimen/lb_browse_header_text_size" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/space"
        android:visibility="gone"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:rotation="180"
            android:background="@drawable/shadow_primary_white"
            android:layout_width="64dp"
            android:layout_height="1dp"/>
        <View
            android:background="@color/card_primary_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="1dp"/>
        <View
            android:background="@drawable/shadow_primary_white"
            android:layout_width="64dp"
            android:layout_height="1dp"/>
    </LinearLayout>
</androidx.leanback.widget.NonOverlappingLinearLayout>